+      temperature: 0.4,
+      topP: 0.8,
+      provider: ModelProviderEnum.OpenAI,
+      modelId: 'gpt-5.4',
+      providerOptions: {
+        openai: {
+          reasoningEffort: 'xhigh',
+        },
+      },
+    })
