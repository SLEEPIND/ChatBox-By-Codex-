@@ -0,0 +1,12 @@
+import { describe, expect, it } from 'vitest'
+import config from '../capacitor.config'
+
+describe('Capacitor Android edge-to-edge handling', () => {
+  it('lets Capacitor apply Android system bar margins instead of drawing the WebView under the status bar', () => {
+    expect(config.android?.adjustMarginsForEdgeToEdge).toBe('auto')
+  })
+
+  it('enables the Android keyboard resize workaround used by edge-to-edge WebViews', () => {
+    expect(config.plugins?.Keyboard?.resizeOnFullScreen).toBe(true)
+  })
+})
