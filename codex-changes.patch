diff --git a/src/renderer/components/settings/OpenAIReasoningEffortControl.tsx b/src/renderer/components/settings/OpenAIReasoningEffortControl.tsx
new file mode 100644
index 0000000..454efec
--- /dev/null
+++ b/src/renderer/components/settings/OpenAIReasoningEffortControl.tsx
@@ -0,0 +1,65 @@
+import { Flex, Stack, Text, Tooltip } from '@mantine/core'
+import type { ReasoningEffort } from '@shared/types/settings'
+import { IconInfoCircle } from '@tabler/icons-react'
+import { useCallback, useMemo } from 'react'
+import { useTranslation } from 'react-i18next'
+import { ScalableIcon } from '@/components/common/ScalableIcon'
+import SegmentedControl from '@/components/common/SegmentedControl'
+
+interface OpenAIReasoningEffortControlProps {
+  value?: ReasoningEffort
+  onChange: (reasoningEffort: ReasoningEffort | undefined) => void
+}
+
+export default function OpenAIReasoningEffortControl({ value, onChange }: OpenAIReasoningEffortControlProps) {
+  const { t } = useTranslation()
+
+  const reasoningEffortOptions = useMemo(
+    () => [
+      { label: t('Not set'), value: 'null' },
+      { label: t('Disable thinking'), value: 'disabled' },
+      { label: t('Low'), value: 'low' },
+      { label: t('Medium'), value: 'medium' },
+      { label: t('High'), value: 'high' },
+      { label: t('XHigh'), value: 'xhigh' },
+    ],
+    [t]
+  )
+
+  const handleReasoningEffortChange = useCallback(
+    (nextValue: string) => {
+      onChange(nextValue === 'null' ? undefined : (nextValue as ReasoningEffort))
+    },
+    [onChange]
+  )
+
+  return (
+    <Stack gap="md" style={{ minWidth: 0 }}>
+      <Flex align="center" gap="xs">
+        <Text size="sm" fw="600">
+          {t('Thinking Effort')}
+        </Text>
+        <Tooltip
+          label={t('Thinking Effort is sent to providers that accept reasoning_effort')}
+          withArrow={true}
+          maw={320}
+          className="!whitespace-normal"
+          zIndex={3000}
+          events={{ hover: true, focus: true, touch: true }}
+        >
+          <ScalableIcon icon={IconInfoCircle} size={20} className="text-chatbox-tint-tertiary" />
+        </Tooltip>
+      </Flex>
+
+      <div style={{ minWidth: 0, overflowX: 'auto' }}>
+        <SegmentedControl
+          key="reasoning-effort-control"
+          value={value ?? 'null'}
+          onChange={handleReasoningEffortChange}
+          data={reasoningEffortOptions}
+          fullWidth={false}
+        />
+      </div>
+    </Stack>
+  )
+}
