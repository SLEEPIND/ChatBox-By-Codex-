+import { describe, expect, it } from 'vitest'
+import {
+  buildOpenAICompatibleReasoningProviderOptions,
+  buildOpenAIReasoningProviderOptions,
+  createReasoningEffortDebugPayload,
+  getReasoningEffort,
+  getReasoningEffortDebugLogging,
+  updateReasoningEffortDebugLoggingProviderOptions,
+  updateReasoningEffortProviderOptions,
+} from './reasoning-effort'
+
+describe('reasoning effort provider options', () => {
+  it('stores reasoning effort as a generic provider option and clears legacy OpenAI-only value', () => {
+    const updated = updateReasoningEffortProviderOptions(
+      {
+        openai: {
+          reasoningEffort: 'xhigh',
+        },
+        google: {
+          thinkingConfig: {
+            thinkingBudget: 1024,
+            includeThoughts: true,
+          },
+        },
+      },
+      'high'
+    )
+
+    expect(updated).toEqual({
+      reasoningEffort: 'high',
+      google: {
+        thinkingConfig: {
+          thinkingBudget: 1024,
+          includeThoughts: true,
+        },
+      },
+    })
+  })
+
+  it('reads generic reasoning effort with legacy OpenAI fallback', () => {
+    expect(getReasoningEffort({ reasoningEffort: 'medium' })).toBe('medium')
+    expect(getReasoningEffort({ openai: { reasoningEffort: 'xhigh' } })).toBe('xhigh')
+  })
+
+  it('builds OpenAI request options with xhigh unchanged', () => {
+    expect(buildOpenAIReasoningProviderOptions({ reasoningEffort: 'xhigh' })).toEqual({
+      openai: {
+        reasoningEffort: 'xhigh',
+      },
+    })
+  })
+
+  it('builds OpenAI-compatible extra body options with thinking enabled', () => {
+    expect(buildOpenAICompatibleReasoningProviderOptions({ reasoningEffort: 'xhigh' }, 'DeepSeek')).toEqual({
+      openaiCompatible: {
+        reasoningEffort: 'xhigh',
+      },
+      DeepSeek: {
+        thinking: {
+          type: 'enabled',
+        },
+      },
+    })
+  })
+
+  it('stores disabled thinking separately from an unset default', () => {
+    const updated = updateReasoningEffortProviderOptions({ reasoningEffort: 'xhigh' }, 'disabled')
+
+    expect(updated).toEqual({
+      reasoningEffort: 'disabled',
+    })
+    expect(getReasoningEffort(updated)).toBe('disabled')
+  })
+
+  it('builds OpenAI-compatible options that explicitly disable thinking without sending reasoning effort', () => {
+    expect(buildOpenAICompatibleReasoningProviderOptions({ reasoningEffort: 'disabled' }, 'DeepSeek')).toEqual({
+      openaiCompatible: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+      DeepSeek: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+    })
+  })
+
+  it('does not send OpenAI reasoning effort when thinking is disabled', () => {
+    expect(buildOpenAIReasoningProviderOptions({ reasoningEffort: 'disabled' })).toBeUndefined()
+  })
+
+  it('stores and clears reasoning effort debug logging without leaking into request options', () => {
+    expect(updateReasoningEffortDebugLoggingProviderOptions({ reasoningEffort: 'high' }, true)).toEqual({
+      reasoningEffort: 'high',
+      debugReasoningEffortLogging: true,
+    })
+    expect(getReasoningEffortDebugLogging({ debugReasoningEffortLogging: true })).toBe(true)
+    expect(
+      updateReasoningEffortDebugLoggingProviderOptions({ debugReasoningEffortLogging: true }, false)
+    ).toBeUndefined()
+    expect(
+      buildOpenAICompatibleReasoningProviderOptions(
+        { reasoningEffort: 'xhigh', debugReasoningEffortLogging: true },
+        'DeepSeek'
+      )
+    ).toEqual({
+      openaiCompatible: {
+        reasoningEffort: 'xhigh',
+      },
+      DeepSeek: {
+        thinking: {
+          type: 'enabled',
+        },
+      },
+    })
+  })
+
+  it('creates a safe debug payload with the effective reasoning parameters only', () => {
+    const requestProviderOptions = buildOpenAICompatibleReasoningProviderOptions(
+      { reasoningEffort: 'xhigh', debugReasoningEffortLogging: true },
+      'DeepSeek'
+    )
+
+    expect(
+      createReasoningEffortDebugPayload(
+        'DeepSeek',
+        { reasoningEffort: 'xhigh', debugReasoningEffortLogging: true },
+        requestProviderOptions
+      )
+    ).toEqual({
+      tag: 'reasoning-effort-debug',
+      provider: 'DeepSeek',
+      selectedReasoningEffort: 'xhigh',
+      requestProviderOptions: {
+        openaiCompatible: {
+          reasoning_effort: 'xhigh',
+        },
+        DeepSeek: {
+          thinking: {
+            type: 'enabled',
+          },
+        },
+      },
+    })
+  })
+})
diff --git a/src/shared/utils/reasoning-effort.ts b/src/shared/utils/reasoning-effort.ts
new file mode 100644
index 0000000..0be0530
--- /dev/null
+++ b/src/shared/utils/reasoning-effort.ts
@@ -0,0 +1,183 @@
+import type { JSONValue } from 'ai'
+import type { ProviderOptions, ReasoningEffort } from '../types/settings'
+
+type RequestProviderOptions = Record<string, Record<string, JSONValue>>
+type ReasoningEffortDebugRequestProviderOptions = Record<string, Record<string, JSONValue>>
+
+const REASONING_EFFORT_DEBUG_LOG_TAG = 'reasoning-effort-debug'
+
+export function getReasoningEffort(providerOptions: ProviderOptions | undefined): ReasoningEffort | undefined {
+  return (
+    providerOptions?.reasoningEffort ??
+    providerOptions?.openai?.reasoningEffort ??
+    providerOptions?.openaiCompatible?.reasoningEffort ??
+    providerOptions?.deepseek?.reasoningEffort
+  )
+}
+
+export function updateReasoningEffortProviderOptions(
+  providerOptions: ProviderOptions | undefined,
+  reasoningEffort: ReasoningEffort | undefined
+): ProviderOptions | undefined {
+  const nextProviderOptions: ProviderOptions = { ...(providerOptions || {}) }
+
+  if (reasoningEffort) {
+    nextProviderOptions.reasoningEffort = reasoningEffort
+  } else {
+    delete nextProviderOptions.reasoningEffort
+  }
+
+  const nextOpenAIOptions = { ...(nextProviderOptions.openai || {}) }
+  delete nextOpenAIOptions.reasoningEffort
+  if (Object.keys(nextOpenAIOptions).length > 0) {
+    nextProviderOptions.openai = nextOpenAIOptions
+  } else {
+    delete nextProviderOptions.openai
+  }
+
+  const nextOpenAICompatibleOptions = { ...(nextProviderOptions.openaiCompatible || {}) }
+  delete nextOpenAICompatibleOptions.reasoningEffort
+  if (Object.keys(nextOpenAICompatibleOptions).length > 0) {
+    nextProviderOptions.openaiCompatible = nextOpenAICompatibleOptions
+  } else {
+    delete nextProviderOptions.openaiCompatible
+  }
+
+  const nextDeepSeekOptions = { ...(nextProviderOptions.deepseek || {}) }
+  delete nextDeepSeekOptions.reasoningEffort
+  if (Object.keys(nextDeepSeekOptions).length > 0) {
+    nextProviderOptions.deepseek = nextDeepSeekOptions
+  } else {
+    delete nextProviderOptions.deepseek
+  }
+
+  return Object.keys(nextProviderOptions).length > 0 ? nextProviderOptions : undefined
+}
+
+export function getReasoningEffortDebugLogging(providerOptions: ProviderOptions | undefined): boolean {
+  return providerOptions?.debugReasoningEffortLogging === true
+}
+
+export function updateReasoningEffortDebugLoggingProviderOptions(
+  providerOptions: ProviderOptions | undefined,
+  enabled: boolean
+): ProviderOptions | undefined {
+  const nextProviderOptions: ProviderOptions = { ...(providerOptions || {}) }
+
+  if (enabled) {
+    nextProviderOptions.debugReasoningEffortLogging = true
+  } else {
+    delete nextProviderOptions.debugReasoningEffortLogging
+  }
+
+  return Object.keys(nextProviderOptions).length > 0 ? nextProviderOptions : undefined
+}
+
+export function buildOpenAIReasoningProviderOptions(
+  providerOptions: ProviderOptions | undefined
+): RequestProviderOptions | undefined {
+  const reasoningEffort = getReasoningEffort(providerOptions)
+  if (!reasoningEffort || reasoningEffort === 'disabled') {
+    return undefined
+  }
+
+  return {
+    openai: {
+      reasoningEffort,
+    },
+  }
+}
+
+export function buildOpenAICompatibleReasoningProviderOptions(
+  providerOptions: ProviderOptions | undefined,
+  providerOptionsName: string
+): RequestProviderOptions | undefined {
+  const reasoningEffort = getReasoningEffort(providerOptions)
+  if (!reasoningEffort) {
+    return undefined
+  }
+
+  if (reasoningEffort === 'disabled') {
+    return {
+      openaiCompatible: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+      [providerOptionsName]: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+    }
+  }
+
+  return {
+    openaiCompatible: {
+      reasoningEffort,
+    },
+    [providerOptionsName]: {
+      thinking: {
+        type: 'enabled',
+      },
+    },
+  }
+}
+
+function sanitizeReasoningProviderOptions(
+  requestProviderOptions: RequestProviderOptions | undefined
+): ReasoningEffortDebugRequestProviderOptions {
+  const sanitized: ReasoningEffortDebugRequestProviderOptions = {}
+
+  for (const [providerName, providerSettings] of Object.entries(requestProviderOptions || {})) {
+    const sanitizedProviderSettings: Record<string, JSONValue> = {}
+    const reasoningEffort = providerSettings.reasoningEffort
+    if (typeof reasoningEffort === 'string') {
+      sanitizedProviderSettings.reasoning_effort = reasoningEffort
+    }
+
+    const thinking = providerSettings.thinking
+    if (thinking && typeof thinking === 'object' && !Array.isArray(thinking)) {
+      const thinkingType = (thinking as Record<string, JSONValue>).type
+      if (typeof thinkingType === 'string') {
+        sanitizedProviderSettings.thinking = {
+          type: thinkingType,
+        }
+      }
+    }
+
+    if (Object.keys(sanitizedProviderSettings).length > 0) {
+      sanitized[providerName] = sanitizedProviderSettings
+    }
+  }
+
+  return sanitized
+}
+
+export function createReasoningEffortDebugPayload(
+  providerName: string,
+  providerOptions: ProviderOptions | undefined,
+  requestProviderOptions: RequestProviderOptions | undefined
+) {
+  if (!getReasoningEffortDebugLogging(providerOptions)) {
+    return undefined
+  }
+
+  return {
+    tag: REASONING_EFFORT_DEBUG_LOG_TAG,
+    provider: providerName,
+    selectedReasoningEffort: getReasoningEffort(providerOptions) ?? null,
+    requestProviderOptions: sanitizeReasoningProviderOptions(requestProviderOptions),
+  }
+}
+
+export function logReasoningEffortRequest(
+  providerName: string,
+  providerOptions: ProviderOptions | undefined,
+  requestProviderOptions: RequestProviderOptions | undefined
+) {
+  const payload = createReasoningEffortDebugPayload(providerName, providerOptions, requestProviderOptions)
+  if (payload) {
+    console.info(`[${REASONING_EFFORT_DEBUG_LOG_TAG}] ${JSON.stringify(payload)}`)
+  }
+}
