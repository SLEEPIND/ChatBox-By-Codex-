@@ -0,0 +1,77 @@
+import { describe, expect, it } from 'vitest'
+import { settings } from '../defaults'
+import { ProviderOptionsSchema, SessionSettingsSchema, SettingsSchema } from './settings'
+
+describe('OpenAI reasoning effort settings', () => {
+  it('accepts xhigh as an OpenAI reasoning effort provider option', () => {
+    const parsed = ProviderOptionsSchema.parse({
+      openai: {
+        reasoningEffort: 'xhigh',
+      },
+    })
+
+    expect(parsed.openai?.reasoningEffort).toBe('xhigh')
+  })
+
+  it('preserves xhigh on per-session settings', () => {
+    const parsed = SessionSettingsSchema.parse({
+      providerOptions: {
+        openai: {
+          reasoningEffort: 'xhigh',
+        },
+      },
+    })
+
+    expect(parsed.providerOptions?.openai?.reasoningEffort).toBe('xhigh')
+  })
+
+  it('preserves xhigh on global settings for new conversations', () => {
+    const parsed = SettingsSchema.parse({
+      ...settings(),
+      providerOptions: {
+        openai: {
+          reasoningEffort: 'xhigh',
+        },
+      },
+    })
+
+    expect(parsed.providerOptions?.openai?.reasoningEffort).toBe('xhigh')
+  })
+
+  it('does not persist max as a reasoning effort option', () => {
+    const parsed = ProviderOptionsSchema.parse({
+      reasoningEffort: 'max',
+      openaiCompatible: {
+        reasoningEffort: 'max',
+      },
+    })
+
+    expect(parsed.reasoningEffort).toBeUndefined()
+    expect(parsed.openaiCompatible?.reasoningEffort).toBeUndefined()
+  })
+
+  it('preserves the reasoning effort debug logging switch in session and global settings', () => {
+    const session = SessionSettingsSchema.parse({
+      providerOptions: {
+        debugReasoningEffortLogging: true,
+      },
+    })
+    const global = SettingsSchema.parse({
+      ...settings(),
+      providerOptions: {
+        debugReasoningEffortLogging: true,
+      },
+    })
+
+    expect(session.providerOptions?.debugReasoningEffortLogging).toBe(true)
+    expect(global.providerOptions?.debugReasoningEffortLogging).toBe(true)
+  })
+
+  it('preserves disabled thinking as a distinct reasoning option', () => {
+    const parsed = ProviderOptionsSchema.parse({
+      reasoningEffort: 'disabled',
+    })
+
+    expect(parsed.reasoningEffort).toBe('disabled')
+  })
+})
