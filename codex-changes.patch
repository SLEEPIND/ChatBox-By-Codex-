@@ -0,0 +1,21 @@
+import type { SessionSettings, Settings } from '@shared/types'
+
+type ChatModelSelection = Pick<SessionSettings, 'provider' | 'modelId'> | undefined
+
+export function buildDefaultChatSessionSettings(
+  settings: Settings,
+  lastUsedChatModel: ChatModelSelection
+): SessionSettings {
+  return {
+    maxContextMessageCount: settings.maxContextMessageCount ?? Number.MAX_SAFE_INTEGER,
+    temperature: settings.temperature || undefined,
+    topP: settings.topP || undefined,
+    ...(settings.providerOptions ? { providerOptions: settings.providerOptions } : {}),
+    ...(settings.defaultChatModel
+      ? {
+          provider: settings.defaultChatModel.provider,
+          modelId: settings.defaultChatModel.model,
+        }
+      : lastUsedChatModel || {}),
+  }
+}
