@@ -0,0 +1,33 @@
+import type { ShortcutSendValue } from '../types'
+
+type KeyboardShortcutEvent = {
+  key?: string
+  keyCode?: number
+  shiftKey?: boolean
+  ctrlKey?: boolean
+  altKey?: boolean
+  metaKey?: boolean
+}
+
+export function isEnterShortcutPressed(shortcut: ShortcutSendValue, event: KeyboardShortcutEvent): boolean {
+  const isEnter = event.key === 'Enter' || event.keyCode === 13
+  if (!isEnter) {
+    return false
+  }
+
+  return (
+    {
+      '': false,
+      Enter: !event.shiftKey && !event.ctrlKey && !event.altKey && !event.metaKey,
+      'CommandOrControl+Enter': (event.ctrlKey || event.metaKey) && !event.shiftKey,
+      'Ctrl+Enter': event.ctrlKey && !event.shiftKey,
+      'Command+Enter': event.metaKey,
+      'Shift+Enter': event.shiftKey,
+      'Ctrl+Shift+Enter': event.ctrlKey && event.shiftKey,
+    } satisfies Record<ShortcutSendValue, boolean>
+  )[shortcut]
+}
+
+export function shouldSubmitInputOnShortcut(_event: KeyboardShortcutEvent & { shortcut: ShortcutSendValue }): boolean {
+  return false
+}
