+import { describe, expect, it } from 'vitest'
+import { shouldSubmitInputOnShortcut } from './input-shortcuts'
+
+describe('input shortcut handling', () => {
+  it('does not submit when plain Enter is pressed', () => {
+    expect(
+      shouldSubmitInputOnShortcut({
+        shortcut: 'Enter',
+        key: 'Enter',
+        keyCode: 13,
+      })
+    ).toBe(false)
+  })
+
+  it('does not submit from modifier based send shortcuts either', () => {
+    expect(
+      shouldSubmitInputOnShortcut({
+        shortcut: 'Ctrl+Enter',
+        key: 'Enter',
+        keyCode: 13,
+        ctrlKey: true,
+      })
+    ).toBe(false)
+  })
+})
