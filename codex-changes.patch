+import { describe, expect, it, vi } from 'vitest'
+import DeepSeek from './deepseek'
+
+class TestDeepSeek extends DeepSeek {
+  public exposeCallSettings(options: CallChatCompletionOptions = {}) {
+    return this.getCallSettings(options)
+  }
+}
+
+function createDependencies(): ModelDependencies {
+  return {
+    request: {
+      apiRequest: vi.fn(),
+      fetchWithOptions: vi.fn(),
+    },
+    storage: {
+      saveImage: vi.fn(),
+      getImage: vi.fn(),
+    },
+    sentry: {
+      captureException: vi.fn(),
+      withScope: vi.fn((callback: (scope: SentryScope) => void) =>
+        callback({
+          setTag: vi.fn(),
+          setExtra: vi.fn(),
+        })
+      ),
+    },
+    getRemoteConfig: vi.fn(),
+    platformType: 'desktop',
+  }
+}
+
+function createModel(model: Partial<ProviderModelInfo> = {}) {
+  return new TestDeepSeek(
+    {
+      apiKey: 'test-key',
+      model: {
+        modelId: 'deepseek-v4-pro',
+        type: 'chat',
+        capabilities: ['reasoning', 'tool_use'],
+        ...model,
+      },
+    },
+    createDependencies()
+  )
+}
+
+describe('DeepSeek call settings', () => {
+  it('passes generic reasoning effort as DeepSeek thinking extra body', () => {
+    const deepseek = createModel()
+
+    const settings = deepseek.exposeCallSettings({
+      providerOptions: {
+        reasoningEffort: 'xhigh',
+      },
+    })
+
+    expect(settings.providerOptions).toEqual({
+      openaiCompatible: {
+        reasoningEffort: 'xhigh',
+      },
+      DeepSeek: {
+        thinking: {
+          type: 'enabled',
+        },
+      },
+    })
+  })
+
+  it('keeps thinking enabled for known reasoning models when effort is unset', () => {
+    const deepseek = createModel({ modelId: 'deepseek-reasoner' })
+
+    const settings = deepseek.exposeCallSettings()
+
+    expect(settings.providerOptions).toEqual({
+      DeepSeek: {
+        thinking: {
+          type: 'enabled',
+        },
+      },
+    })
+  })
+
+  it('keeps thinking disabled when explicitly selected even for known reasoning models', () => {
+    const deepseek = createModel({ modelId: 'deepseek-reasoner' })
+
+    const settings = deepseek.exposeCallSettings({
+      providerOptions: {
+        reasoningEffort: 'disabled',
+      },
+    })
+
+    expect(settings.providerOptions).toEqual({
+      openaiCompatible: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+      DeepSeek: {
+        thinking: {
+          type: 'disabled',
+        },
+      },
+    })
+  })
+})
